# Скопируйте в .env и заполните значения

# --- LLM ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Модель для RCA-анализа и извлечения полей из DOCX.
# Рекомендации (бесплатные, через OpenRouter):
#   nvidia/nemotron-3-super-120b-a12b:free   — 1M контекст, 120B параметров (рекомендуемая)
#   nvidia/nemotron-3-ultra-550b-a55b:free   — 1M контекст, 550B MoE (мощнее, но медленнее)
#   google/gemma-4-26b-a4b-it:free           — 262K контекст, 140+ языков, structured output
#   meta-llama/llama-3.3-70b-instruct:free   — 131K контекст, стабильный JSON, мультиязычный
#   openrouter/free                           — авто-выбор из доступных бесплатных моделей
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Размер контекстного окна модели (токены). Автоопределяется по названию модели,
# но можно задать явно. Для моделей с контекстом ≥ 200K DOCX отправляется целиком.
# OPENROUTER_MODEL_MAX_CONTEXT=1000000

# Максимальный размер текста отчёта (символов) для отправки в LLM.
# Используется ТОЛЬКО когда модель НЕ поддерживает полный текст (< 200K контекст).
# DOCX_MAX_INPUT_CHARS=20000

OPENROUTER_TIMEOUT=120
OPENROUTER_MAX_RETRIES=3

# --- Embeddings (поиск похожих инцидентов) ---
# local       — детерминированный hashing-baseline local/hash-ngrams-v2 (стемминг + HSE-синонимы), без зависимостей
# huggingface — ЛОКАЛЬНАЯ предобученная модель (рекомендуется): настоящая семантика, без API в рантайме.
#               Требует: pip install -e ".[embeddings]" (torch CPU + transformers).
#               Модель скачивается с HF Hub при первом запросе и кэшируется (~120MB для rubert-tiny2).
# openrouter  — семантическая модель через OpenRouter /embeddings (платные запросы)
# При любой ошибке huggingface/openrouter — автоматический фолбэк на local.
EMBEDDINGS_PROVIDER=local
# Модель для EMBEDDINGS_PROVIDER=huggingface:
#   cointegrated/rubert-tiny2        — 29M, ~120MB, лучший баланс для русского (default)
#   intfloat/multilingual-e5-small   — 118M, ~450MB, выше качество, нужен префикс query:
# HF_EMBEDDING_MODEL=cointegrated/rubert-tiny2
# HF_EMBEDDING_MAX_TOKENS=512
# ВАЖНО: у нейросетевых моделей даже несвязанные тексты дают similarity ~0.4-0.5,
# поэтому для huggingface рекомендуемый threshold поиска похожих — 0.55-0.6 (vs 0.15 для local).
# Кэш моделей HF (в Docker монтируйте volume): HF_HOME=/app/.hf-cache
# Модель для EMBEDDINGS_PROVIDER=openrouter (OpenAI-совместимый /embeddings):
#   openai/text-embedding-3-small  — дёшево, Matryoshka (dimensions=384 нативно)
#   openai/text-embedding-3-large  — точнее, дороже
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# OPENROUTER_EMBEDDING_TIMEOUT=30
# OPENROUTER_EMBEDDING_MAX_RETRIES=3

# --- База данных ---
DATABASE_URL=postgresql+asyncpg://rca:secret@db:5432/rca_analyzer

# --- JWT / auth ---
JWT_SECRET=change-me-in-production-please
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=
# AUTH_COOKIE_PATH=/
# ACCESS_COOKIE_NAME=access_token
# REFRESH_COOKIE_NAME=refresh_token

# --- CSRF (signed double-submit cookie) ---
# Защита небезопасных методов при cookie-based auth. Bearer/curl/Swagger освобождены.
CSRF_PROTECTION_ENABLED=true
# Отдельный секрет для подписи CSRF-токена; если пусто — используется JWT_SECRET.
# CSRF_SECRET=
# Доп. exempt-пути (CSV, точное совпадение path). login/register/refresh уже исключены.
# CSRF_EXEMPT_PATHS=
# CSRF_COOKIE_NAME=csrf_token
# CSRF_HEADER_NAME=X-CSRF-Token

# --- Роли ---
# Email пользователя, который автоматически получит role='admin' при старте.
# Пользователь должен быть уже зарегистрирован (или seed сработает после перезапуска).
# ADMIN_EMAIL=admin@example.com

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Приложение ---
LOG_LEVEL=INFO
