# Скопируйте в .env и заполните значения

# --- LLM ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT=60
OPENROUTER_MAX_RETRIES=3

# --- База данных ---
DATABASE_URL=postgresql+asyncpg://rca:secret@db:5432/rca_analyzer

# --- JWT / auth ---
JWT_SECRET=change-me-in-production-please
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=
# AUTH_COOKIE_PATH=/
# ACCESS_COOKIE_NAME=access_token
# REFRESH_COOKIE_NAME=refresh_token

# --- CSRF (signed double-submit cookie) ---
# Защита небезопасных методов при cookie-based auth. Bearer/curl/Swagger освобождены.
CSRF_PROTECTION_ENABLED=true
# Отдельный секрет для подписи CSRF-токена; если пусто — используется JWT_SECRET.
# CSRF_SECRET=
# Доп. exempt-пути (CSV, точное совпадение path). login/register/refresh уже исключены.
# CSRF_EXEMPT_PATHS=
# CSRF_COOKIE_NAME=csrf_token
# CSRF_HEADER_NAME=X-CSRF-Token

# --- Роли ---
# Email пользователя, который автоматически получит role='admin' при старте.
# Пользователь должен быть уже зарегистрирован (или seed сработает после перезапуска).
# ADMIN_EMAIL=admin@example.com

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Приложение ---
LOG_LEVEL=INFO
